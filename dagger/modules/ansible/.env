# **WARNING**
# This file should **never** contains hard-coded secrets.
# Rather, point to a secret in the environment with 'env://{}', or AWS Secrets
# Manager with 'aws+sm://{}'.

# shellcheck disable=SC2034
AWSACCESSKEYID=env://AWS_ACCESS_KEY_ID
AWSSECRETACCESSKEY=env://AWS_SECRET_ACCESS_KEY
AWSSESSIONTOKEN=env://AWS_SESSION_TOKEN
